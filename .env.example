# Supabase (already configured)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Existing
HMAC_SECRET=

# Site URL (used for Stripe success/cancel redirects)
NEXT_PUBLIC_SITE_URL=https://forelandmarine.com

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs — one per tier per currency
# Create three Products in Stripe (Standby / Direct / Captive), each with
# three monthly recurring prices (GBP £250 / EUR €295 / USD $315 etc).
STRIPE_PRICE_STANDBY_GBP=price_xxx
STRIPE_PRICE_STANDBY_EUR=price_xxx
STRIPE_PRICE_STANDBY_USD=price_xxx
STRIPE_PRICE_DIRECT_GBP=price_xxx
STRIPE_PRICE_DIRECT_EUR=price_xxx
STRIPE_PRICE_DIRECT_USD=price_xxx
STRIPE_PRICE_CAPTIVE_GBP=price_xxx
STRIPE_PRICE_CAPTIVE_EUR=price_xxx
STRIPE_PRICE_CAPTIVE_USD=price_xxx

# Resend (transactional email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="Foreland Marine <info@forelandmarine.com>"
