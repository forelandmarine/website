# Supabase (already configured)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Existing
HMAC_SECRET=

# Site URL (used for Stripe success/cancel redirects)
NEXT_PUBLIC_SITE_URL=https://www.forelandmarine.com

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs — one per tier per currency per billing cycle.
# Three Products in Stripe (Standby / Direct / Captive), each with SIX
# recurring prices: monthly + annual, in GBP, EUR, and USD.
# Monthly: £250 / €295 / $315 (Standby), £500 / €585 / $630 (Direct), £1,000 / €1,170 / $1,260 (Captive)
# Annual: £2,500 / €2,950 / $3,150 (Standby), £5,000 / €5,850 / $6,300 (Direct), £10,000 / €11,700 / $12,600 (Captive)
STRIPE_PRICE_STANDBY_GBP_MONTHLY=price_xxx
STRIPE_PRICE_STANDBY_EUR_MONTHLY=price_xxx
STRIPE_PRICE_STANDBY_USD_MONTHLY=price_xxx
STRIPE_PRICE_STANDBY_GBP_ANNUAL=price_xxx
STRIPE_PRICE_STANDBY_EUR_ANNUAL=price_xxx
STRIPE_PRICE_STANDBY_USD_ANNUAL=price_xxx
STRIPE_PRICE_DIRECT_GBP_MONTHLY=price_xxx
STRIPE_PRICE_DIRECT_EUR_MONTHLY=price_xxx
STRIPE_PRICE_DIRECT_USD_MONTHLY=price_xxx
STRIPE_PRICE_DIRECT_GBP_ANNUAL=price_xxx
STRIPE_PRICE_DIRECT_EUR_ANNUAL=price_xxx
STRIPE_PRICE_DIRECT_USD_ANNUAL=price_xxx
STRIPE_PRICE_CAPTIVE_GBP_MONTHLY=price_xxx
STRIPE_PRICE_CAPTIVE_EUR_MONTHLY=price_xxx
STRIPE_PRICE_CAPTIVE_USD_MONTHLY=price_xxx
STRIPE_PRICE_CAPTIVE_GBP_ANNUAL=price_xxx
STRIPE_PRICE_CAPTIVE_EUR_ANNUAL=price_xxx
STRIPE_PRICE_CAPTIVE_USD_ANNUAL=price_xxx

# Resend (transactional email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="Foreland Marine <info@forelandmarine.com>"
